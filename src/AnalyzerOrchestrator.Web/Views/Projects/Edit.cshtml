@model AnalyzerOrchestrator.Application.DTOs.Projects.EditProjectDto
@{
    ViewData["Title"] = "Editar Projeto";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">Detalhes</a></li>
        <li class="breadcrumb-item active">Editar</li>
    </ol>
</nav>

<h2 class="mb-4">Editar Projeto</h2>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Descrição</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RepositoryPath" class="form-label fw-semibold">Caminho do Repositório</label>
                <input asp-for="RepositoryPath" class="form-control" />
                <span asp-validation-for="RepositoryPath" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TechnologyStack" class="form-label fw-semibold">Stack Tecnológica</label>
                <input asp-for="TechnologyStack" class="form-control" />
                <span asp-validation-for="TechnologyStack" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label">Projeto ativo</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
