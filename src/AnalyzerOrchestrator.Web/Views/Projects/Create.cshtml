@model AnalyzerOrchestrator.Application.DTOs.Projects.CreateProjectDto
@{
    ViewData["Title"] = "Novo Projeto";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item active">Novo Projeto</li>
    </ol>
</nav>

<h2 class="mb-4">Novo Projeto</h2>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="Ex: Sistema de Vendas" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">Descrição</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Breve descrição do projeto..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RepositoryPath" class="form-label fw-semibold">Caminho do Repositório</label>
                <input asp-for="RepositoryPath" class="form-control"
                       placeholder="Ex: C:\Projetos\SistemaVendas" />
                <div class="form-text">Caminho local onde o código-fonte está localizado.</div>
                <span asp-validation-for="RepositoryPath" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="TechnologyStack" class="form-label fw-semibold">Stack Tecnológica</label>
                <input asp-for="TechnologyStack" class="form-control"
                       placeholder="Ex: .NET 8, SQL Server, React" />
                <span asp-validation-for="TechnologyStack" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Criar Projeto</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
