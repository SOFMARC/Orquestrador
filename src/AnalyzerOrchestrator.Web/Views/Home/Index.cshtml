@{
    ViewData["Title"] = "Início";
}

<div class="px-4 py-5 text-center">
    <h1 class="display-5 fw-bold">Analyzer Orchestrator</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">
            Sistema local para orquestração de etapas de análise técnica de projetos,
            preparando contexto estruturado para uso com IA.
        </p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a asp-controller="Projects" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3">
                Ver Projetos
            </a>
            <a asp-controller="Projects" asp-action="Create" class="btn btn-outline-secondary btn-lg px-4">
                Novo Projeto
            </a>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-4 py-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Projetos</h5>
                    <p class="card-text text-muted">
                        Cadastre e gerencie os projetos que serão analisados pelo orquestrador.
                    </p>
                    <a asp-controller="Projects" asp-action="Index" class="btn btn-sm btn-outline-primary">Acessar</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Pipeline Runs</h5>
                    <p class="card-text text-muted">
                        Crie e acompanhe execuções do pipeline de análise para cada projeto.
                    </p>
                    <a asp-controller="Projects" asp-action="Index" class="btn btn-sm btn-outline-primary">Acessar via Projeto</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Workflow</h5>
                    <p class="card-text text-muted">
                        Cada run executa etapas estruturadas: coleta, mapeamento, análise e preparação de contexto.
                    </p>
                    <span class="badge bg-secondary">Etapas automáticas</span>
                </div>
            </div>
        </div>
    </div>
</div>
