@model IEnumerable<AnalyzerOrchestrator.Application.DTOs.PipelineRuns.PipelineRunDto>
@{
    var project = ViewBag.Project as AnalyzerOrchestrator.Application.DTOs.Projects.ProjectDto;
    ViewData["Title"] = $"Runs — {project?.Name}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@project?.Id">@project?.Name</a>
        </li>
        <li class="breadcrumb-item active">Pipeline Runs</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Pipeline Runs — <span class="text-muted fs-5">@project?.Name</span></h2>
    <a asp-action="Create" asp-route-projectId="@project?.Id" class="btn btn-primary">+ Novo Run</a>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum run criado para este projeto.
        <a asp-action="Create" asp-route-projectId="@project?.Id">Criar o primeiro run.</a>
    </div>
}
else
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Status</th>
                <th>Etapa Atual</th>
                <th>Início</th>
                <th>Fim</th>
                <th>Progresso</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var run in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@run.Id" class="fw-semibold text-decoration-none">
                            #@run.Id
                        </a>
                    </td>
                    <td>
                        @{
                            var badgeClass = run.Status switch
                            {
                                AnalyzerOrchestrator.Domain.Enums.RunStatus.Completed => "bg-success",
                                AnalyzerOrchestrator.Domain.Enums.RunStatus.Running => "bg-primary",
                                AnalyzerOrchestrator.Domain.Enums.RunStatus.Failed => "bg-danger",
                                AnalyzerOrchestrator.Domain.Enums.RunStatus.Cancelled => "bg-secondary",
                                _ => "bg-warning text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@run.StatusLabel</span>
                    </td>
                    <td><small>@(run.CurrentStep ?? "—")</small></td>
                    <td><small>@(run.StartedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</small></td>
                    <td><small>@(run.FinishedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</small></td>
                    <td>
                        @if (run.TotalSteps > 0)
                        {
                            var pct = (int)((double)run.CompletedSteps / run.TotalSteps * 100);
                            <div class="progress" style="height:6px; width:80px;">
                                <div class="progress-bar" role="progressbar" style="width:@pct%"></div>
                            </div>
                            <small class="text-muted">@run.CompletedSteps/@run.TotalSteps</small>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@run.Id" class="btn btn-sm btn-outline-primary">Detalhes</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
