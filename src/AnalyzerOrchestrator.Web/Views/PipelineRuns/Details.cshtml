@using AnalyzerOrchestrator.Domain.Enums
@model AnalyzerOrchestrator.Application.DTOs.PipelineRuns.PipelineRunDto
@{
    ViewData["Title"] = $"Run #{Model.Id}";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">@Model.ProjectName</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="ByProject" asp-route-projectId="@Model.ProjectId">Runs</a>
        </li>
        <li class="breadcrumb-item active">Run #@Model.Id</li>
    </ol>
</nav>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] is string info)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @info
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2>Pipeline Run <span class="text-muted">#@Model.Id</span></h2>
        <p class="text-muted mb-0">Projeto: <strong>@Model.ProjectName</strong></p>
    </div>
    @{
        var badgeClass = Model.Status switch
        {
            RunStatus.Completed => "bg-success",
            RunStatus.Running => "bg-primary",
            RunStatus.Failed => "bg-danger",
            RunStatus.Cancelled => "bg-secondary",
            _ => "bg-warning text-dark"
        };
    }
    <span class="badge @badgeClass fs-6">@Model.StatusLabel</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Informações do Run</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Origem</dt>
                    <dd class="col-sm-7">@(Model.TriggerSource ?? "—")</dd>

                    <dt class="col-sm-5">Etapa Atual</dt>
                    <dd class="col-sm-7">@(Model.CurrentStep ?? "—")</dd>

                    <dt class="col-sm-5">Início</dt>
                    <dd class="col-sm-7">@(Model.StartedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>

                    <dt class="col-sm-5">Fim</dt>
                    <dd class="col-sm-7">@(Model.FinishedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")</dd>

                    <dt class="col-sm-5">Criado em</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Progresso</div>
            <div class="card-body">
                @if (Model.TotalSteps > 0)
                {
                    var pct = (int)((double)Model.CompletedSteps / Model.TotalSteps * 100);
                    <div class="progress mb-2" style="height:12px;">
                        <div class="progress-bar" role="progressbar" style="width:@pct%">@pct%</div>
                    </div>
                    <p class="text-muted mb-0">@Model.CompletedSteps de @Model.TotalSteps etapas concluídas</p>
                }
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <hr />
                    <p class="mb-0"><strong>Observações:</strong> @Model.Notes</p>
                }
            </div>
        </div>
    </div>
</div>

<h5 class="mb-3">Etapas do Workflow</h5>

@if (!Model.StepExecutions.Any())
{
    <div class="alert alert-light border">Nenhuma etapa registrada.</div>
}
else
{
    <div class="list-group mb-4">
        @foreach (var step in Model.StepExecutions)
        {
            var stepBadge = step.Status switch
            {
                StepStatus.Completed or StepStatus.Approved => "bg-success",
                StepStatus.Running => "bg-primary",
                StepStatus.Failed => "bg-danger",
                StepStatus.Skipped => "bg-secondary",
                StepStatus.Rejected => "bg-danger",
                StepStatus.AwaitingReview => "bg-warning text-dark",
                StepStatus.Executed => "bg-info",
                _ => "bg-light text-dark border"
            };
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <span class="badge bg-light text-dark border me-2">@step.StepNumber</span>
                        <strong>@step.StepName</strong>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge @stepBadge">@step.StatusLabel</span>

                        @* Botão de ação para Etapa 1 — Extração Estrutural *@
                        @if (step.StepNumber == 1)
                        {
                            if (step.CanBeExecuted)
                            {
                                <a asp-controller="Extraction" asp-action="Execute" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-play-fill me-1"></i>Executar
                                </a>
                            }
                            else if (step.CanBeReviewed)
                            {
                                <a asp-controller="Extraction" asp-action="Review"
                                   asp-route-id="@step.Id" asp-route-runId="@Model.Id"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-clipboard-check me-1"></i>Revisar
                                </a>
                                <a asp-controller="Extraction" asp-action="Result" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                            else if (step.IsExecuted)
                            {
                                <a asp-controller="Extraction" asp-action="Result" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                        }

                        @* Botões de ação para Etapa 2 — Consolidação Arquitetural *@
                        @if (step.StepNumber == 2)
                        {
                            @* Verificar se Etapa 1 está aprovada para habilitar execução *@
                            var step1Status = Model.StepExecutions.FirstOrDefault(s => s.StepNumber == 1)?.Status;
                            var step1Approved = step1Status == StepStatus.Approved;

                            if (step.CanBeExecuted && step1Approved)
                            {
                                <a asp-controller="Consolidation" asp-action="Execute" asp-route-runId="@Model.Id"
                                   class="btn btn-sm btn-primary">
                                    <i class="bi bi-diagram-3 me-1"></i>Executar
                                </a>
                            }
                            else if (step.CanBeExecuted && !step1Approved)
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled" title="Aguardando aprovação da Etapa 1">
                                    <i class="bi bi-lock me-1"></i>Aguardando Etapa 1
                                </span>
                            }
                            else if (step.CanBeReviewed)
                            {
                                <a asp-controller="Consolidation" asp-action="Review" asp-route-stepId="@step.Id"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-clipboard-check me-1"></i>Revisar
                                </a>
                                <a asp-controller="Consolidation" asp-action="Result" asp-route-runId="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                            else if (step.IsExecuted)
                            {
                                <a asp-controller="Consolidation" asp-action="Result" asp-route-runId="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                        }

                        @* Botões de ação para Etapa 3 — Mapeamento Inicial de Dados *@
                        @if (step.StepNumber == 3)
                        {
                            var step1StatusDM = Model.StepExecutions.FirstOrDefault(s => s.StepNumber == 1)?.Status;
                            var step1ApprovedDM = step1StatusDM == StepStatus.Approved;

                            if (step.CanBeExecuted && step1ApprovedDM)
                            {
                                <a asp-controller="DataMapping" asp-action="Execute" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-table me-1"></i>Executar
                                </a>
                            }
                            else if (step.CanBeExecuted && !step1ApprovedDM)
                            {
                                <span class="btn btn-sm btn-outline-secondary disabled" title="Aguardando aprovação da Etapa 1">
                                    <i class="bi bi-lock me-1"></i>Aguardando Etapa 1
                                </span>
                            }
                            else if (step.CanBeReviewed)
                            {
                                <a asp-controller="DataMapping" asp-action="Review"
                                   asp-route-id="@step.Id" asp-route-runId="@Model.Id"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-clipboard-check me-1"></i>Revisar
                                </a>
                                <a asp-controller="DataMapping" asp-action="Result" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                            else if (step.IsExecuted)
                            {
                                <a asp-controller="DataMapping" asp-action="Result" asp-route-id="@Model.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye me-1"></i>Ver Resultado
                                </a>
                            }
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(step.Notes))
                {
                    <small class="text-muted d-block mt-1">@step.Notes</small>
                }
                @if (!string.IsNullOrEmpty(step.ErrorMessage))
                {
                    <small class="text-danger d-block mt-1"><strong>Erro:</strong> @step.ErrorMessage</small>
                }

                @* Métricas de execução *@
                @if (step.FilesFound.HasValue)
                {
                    <small class="text-muted d-block mt-1">
                        <i class="bi bi-files me-1"></i>
                        @step.FilesFound encontrados · @step.FilesIgnored ignorados
                        @if (step.ErrorCount > 0)
                        {
                            <span class="text-danger ms-2">· @step.ErrorCount erros</span>
                        }
                    </small>
                }

                @* Revisão *@
                @if (step.ReviewedAt.HasValue)
                {
                    <small class="text-muted d-block mt-1">
                        <i class="bi bi-person-check me-1"></i>
                        Revisado por @(step.ReviewedBy ?? "anônimo") em @step.ReviewedAt.Value.ToLocalTime().ToString("dd/MM HH:mm")
                        @if (!string.IsNullOrWhiteSpace(step.ReviewNotes))
                        {
                            <span class="ms-2">— @step.ReviewNotes</span>
                        }
                    </small>
                }

                @if (step.StartedAt.HasValue || step.FinishedAt.HasValue)
                {
                    <small class="text-muted d-block mt-1">
                        @if (step.StartedAt.HasValue)
                        {
                            <span>Início: @step.StartedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                        }
                        @if (step.FinishedAt.HasValue)
                        {
                            <span class="ms-2">Fim: @step.FinishedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                        }
                    </small>
                }
            </div>
        }
    </div>
}

@if (Model.Status != RunStatus.Completed && Model.Status != RunStatus.Cancelled)
{
    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
          onsubmit="return confirm('Cancelar este run?')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-outline-danger">Cancelar Run</button>
    </form>
}
