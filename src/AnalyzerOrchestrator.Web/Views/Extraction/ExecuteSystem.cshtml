@using AnalyzerOrchestrator.Application.DTOs.PipelineRuns
@{
    ViewData["Title"] = "Executar Etapa 1 — Extração do sistema";
    var run = ViewBag.Run as PipelineRunDto;
}
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@run?.ProjectId">@run?.ProjectName</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="PipelineRuns" asp-action="Details" asp-route-id="@run?.Id">Análise #@run?.Id</a>
        </li>
        <li class="breadcrumb-item active">Extração do sistema</li>
    </ol>
</nav>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-search me-2"></i>Etapa 1 — Extração do sistema</h5>
    </div>
    <div class="card-body">
        <p class="text-muted">
            Esta etapa consolida a visão técnica completa do projeto em uma única execução,
            percorrendo três subetapas internas em sequência.
        </p>
        <div class="alert alert-light border mb-3">
            <strong>Projeto:</strong> @run?.ProjectName &nbsp;|&nbsp;
            <strong>Análise:</strong> #@run?.Id &nbsp;|&nbsp;
            <strong>Status:</strong> <span class="badge bg-secondary">@run?.StatusLabel</span>
        </div>

        <h6 class="mt-3 mb-2">Subetapas executadas automaticamente:</h6>
        <div class="list-group mb-4">
            <div class="list-group-item">
                <div class="d-flex align-items-start">
                    <span class="badge bg-primary me-3 mt-1">1.1</span>
                    <div>
                        <strong>Extração Estrutural</strong>
                        <p class="text-muted small mb-1">
                            Varre o diretório do projeto, inventaria todos os arquivos, gera a árvore estrutural
                            e identifica os arquivos mais relevantes para análise com IA.
                        </p>
                        <span class="badge bg-light text-dark border me-1">inventory.json</span>
                        <span class="badge bg-light text-dark border me-1">tree.txt</span>
                        <span class="badge bg-light text-dark border me-1">relevant-files.json</span>
                        <span class="badge bg-light text-dark border">summary.md</span>
                    </div>
                </div>
            </div>
            <div class="list-group-item">
                <div class="d-flex align-items-start">
                    <span class="badge bg-success me-3 mt-1">1.2</span>
                    <div>
                        <strong>Consolidação Arquitetural</strong>
                        <p class="text-muted small mb-1">
                            Agrupa os arquivos em módulos e camadas, identifica os arquivos centrais
                            e gera o resumo arquitetural do projeto.
                        </p>
                        <span class="badge bg-light text-dark border me-1">modules-map.json</span>
                        <span class="badge bg-light text-dark border me-1">architecture-summary.md</span>
                        <span class="badge bg-light text-dark border me-1">layer-distribution.json</span>
                        <span class="badge bg-light text-dark border">central-files.json</span>
                    </div>
                </div>
            </div>
            <div class="list-group-item">
                <div class="d-flex align-items-start">
                    <span class="badge bg-info text-white me-3 mt-1">1.3</span>
                    <div>
                        <strong>Mapeamento Inicial de Dados</strong>
                        <p class="text-muted small mb-1">
                            Detecta tabelas e estruturas de dados por heurística, mapeia relações
                            entre tabelas e arquivos, e identifica operações por tabela.
                        </p>
                        <span class="badge bg-light text-dark border me-1">detected-tables.json</span>
                        <span class="badge bg-light text-dark border me-1">table-file-relations.json</span>
                        <span class="badge bg-light text-dark border">table-operations.json</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-warning small mb-4">
            <i class="bi bi-clock me-1"></i>
            <strong>Tempo estimado:</strong> depende do tamanho do projeto.
            Projetos grandes podem levar alguns minutos. Não feche a janela durante a execução.
        </div>

        <form asp-action="ExecuteSystem" asp-route-id="@run?.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-lg"
                        onclick="this.disabled=true; this.innerHTML='<span class=\'spinner-border spinner-border-sm me-2\'></span>Executando...'; this.form.submit();">
                    <i class="bi bi-play-fill me-1"></i> Iniciar Extração do Sistema
                </button>
                <a asp-controller="PipelineRuns" asp-action="Details" asp-route-id="@run?.Id"
                   class="btn btn-outline-secondary btn-lg">Cancelar</a>
            </div>
        </form>
    </div>
</div>
