@using AnalyzerOrchestrator.Application.DTOs.Extraction
@using AnalyzerOrchestrator.Application.DTOs.PipelineRuns
@using AnalyzerOrchestrator.Domain.Enums
@model ExtractionResultDto
@{
    ViewData["Title"] = "Resultado da Extração Estrutural";
    var run = ViewBag.Run as PipelineRunDto;
    var step = ViewBag.Step as PipelineStepExecutionDto;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Projects" asp-action="Index">Projetos</a></li>
        <li class="breadcrumb-item">
            <a asp-controller="PipelineRuns" asp-action="ByProject" asp-route-id="@run?.ProjectId">@run?.ProjectName</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="PipelineRuns" asp-action="Details" asp-route-id="@run?.Id">Run #@run?.Id</a>
        </li>
        <li class="breadcrumb-item active">Resultado — Extração Estrutural</li>
    </ol>
</nav>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">
        @TempData["Info"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-search me-2"></i>Extração Estrutural — Run #@run?.Id</h2>
    @if (step?.CanBeReviewed == true)
    {
        <a asp-action="Review" asp-route-id="@step.Id"
           asp-route-runId="@run?.Id"
           class="btn btn-warning">
            <i class="bi bi-clipboard-check me-1"></i> Revisar Resultado
        </a>
    }
    else if (step?.CanBeExecuted == true)
    {
        <a asp-action="Execute" asp-route-id="@run?.Id" class="btn btn-primary">
            <i class="bi bi-play-fill me-1"></i> Executar Extração
        </a>
    }
</div>

@if (Model is null || step?.Status == StepStatus.Pending)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        A extração ainda não foi executada para esta run.
        <a asp-action="Execute" asp-route-id="@run?.Id" class="alert-link ms-2">Executar agora</a>
    </div>
}
else
{
    <!-- Status da etapa -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="fs-1 fw-bold text-primary">@Model.FilesFound</div>
                    <div class="text-muted small">Arquivos Encontrados</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="fs-1 fw-bold text-success">@Model.RelevantFilesCount</div>
                    <div class="text-muted small">Arquivos Relevantes</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="fs-1 fw-bold text-secondary">@Model.FilesIgnored</div>
                    <div class="text-muted small">Arquivos Ignorados</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-0 shadow-sm">
                <div class="card-body">
                    @{
                        var statusColor = step?.Status switch
                        {
                            StepStatus.Approved => "success",
                            StepStatus.Rejected => "danger",
                            StepStatus.AwaitingReview => "warning",
                            StepStatus.Failed => "danger",
                            _ => "secondary"
                        };
                    }
                    <div class="fs-5 fw-bold text-@statusColor mt-2">
                        <span class="badge bg-@statusColor fs-6">@step?.StatusLabel</span>
                    </div>
                    <div class="text-muted small mt-1">Status da Etapa</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revisão humana (se já revisada) -->
    @if (step?.ReviewedAt.HasValue == true)
    {
        <div class="card mb-4 border-@(step.Status == StepStatus.Approved ? "success" : "danger")">
            <div class="card-header bg-@(step.Status == StepStatus.Approved ? "success" : "danger") text-white">
                <i class="bi bi-@(step.Status == StepStatus.Approved ? "check-circle" : "x-circle") me-2"></i>
                Revisão — @(step.Status == StepStatus.Approved ? "Aprovada" : "Reprovada")
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Revisado por</dt>
                    <dd class="col-sm-9">@(step.ReviewedBy ?? "Anônimo")</dd>
                    <dt class="col-sm-3">Data</dt>
                    <dd class="col-sm-9">@step.ReviewedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                    @if (!string.IsNullOrWhiteSpace(step.ReviewNotes))
                    {
                        <dt class="col-sm-3">Observações</dt>
                        <dd class="col-sm-9">@step.ReviewNotes</dd>
                    }
                </dl>
            </div>
        </div>
    }

    <!-- Árvore estrutural -->
    @if (!string.IsNullOrWhiteSpace(Model.StructureTree))
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-diagram-3 me-2"></i>Árvore Estrutural</span>
                @if (Model.TreeFilePath != null)
                {
                    <small class="text-muted font-monospace">@Model.TreeFilePath</small>
                }
            </div>
            <div class="card-body p-0">
                <pre class="m-0 p-3 bg-dark text-light rounded-bottom" style="max-height:400px;overflow-y:auto;font-size:0.8rem;">@Model.StructureTree</pre>
            </div>
        </div>
    }

    <!-- Arquivos relevantes -->
    @if (Model.RelevantFiles.Any())
    {
        <div class="card mb-4 shadow-sm">
            <div class="card-header">
                <i class="bi bi-star-fill text-warning me-2"></i>Arquivos Relevantes (@Model.RelevantFiles.Count)
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Arquivo</th>
                                <th>Papel</th>
                                <th>Score</th>
                                <th>Tamanho</th>
                                <th>Observação</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in Model.RelevantFiles)
                            {
                                <tr>
                                    <td class="font-monospace small">@f.RelativePath</td>
                                    <td><span class="badge bg-secondary">@f.RoleLabel</span></td>
                                    <td>
                                        <div class="progress" style="height:16px;min-width:60px;">
                                            <div class="progress-bar bg-success" style="width:@f.RelevanceScore%">
                                                <small>@f.RelevanceScore</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@(Math.Round(f.SizeBytes / 1024.0, 1)) KB</td>
                                    <td class="text-muted small">@f.ClassificationNotes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Artefatos gerados -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header"><i class="bi bi-folder2-open me-2"></i>Artefatos Gerados</div>
        <div class="card-body">
            <div class="row g-3">
                @if (Model.InventoryFilePath != null)
                {
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-2 border rounded">
                            <i class="bi bi-file-earmark-text fs-4 text-primary me-3"></i>
                            <div>
                                <div class="fw-semibold">inventory.json</div>
                                <div class="text-muted small font-monospace">@Model.InventoryFilePath</div>
                            </div>
                        </div>
                    </div>
                }
                @if (Model.TreeFilePath != null)
                {
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-2 border rounded">
                            <i class="bi bi-diagram-3 fs-4 text-success me-3"></i>
                            <div>
                                <div class="fw-semibold">tree.txt</div>
                                <div class="text-muted small font-monospace">@Model.TreeFilePath</div>
                            </div>
                        </div>
                    </div>
                }
                @if (Model.RelevantFilesPath != null)
                {
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-2 border rounded">
                            <i class="bi bi-star fs-4 text-warning me-3"></i>
                            <div>
                                <div class="fw-semibold">relevant-files.json</div>
                                <div class="text-muted small font-monospace">@Model.RelevantFilesPath</div>
                            </div>
                        </div>
                    </div>
                }
                @if (Model.SummaryFilePath != null)
                {
                    <div class="col-md-6">
                        <div class="d-flex align-items-center p-2 border rounded">
                            <i class="bi bi-file-earmark-medical fs-4 text-info me-3"></i>
                            <div>
                                <div class="fw-semibold">summary.md</div>
                                <div class="text-muted small font-monospace">@Model.SummaryFilePath</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Todos os arquivos (collapsible) -->
    @if (Model.AllFiles.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header">
                <button class="btn btn-link text-decoration-none p-0 fw-semibold"
                        data-bs-toggle="collapse" data-bs-target="#allFilesCollapse">
                    <i class="bi bi-list-ul me-2"></i>Todos os Arquivos (@Model.AllFiles.Count)
                    <i class="bi bi-chevron-down ms-1"></i>
                </button>
            </div>
            <div id="allFilesCollapse" class="collapse">
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:400px;overflow-y:auto;">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Arquivo</th>
                                    <th>Papel</th>
                                    <th>Score</th>
                                    <th>Relevante</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var f in Model.AllFiles)
                                {
                                    <tr class="@(f.IsRelevant ? "table-warning" : "")">
                                        <td class="font-monospace small">@f.RelativePath</td>
                                        <td><span class="badge bg-secondary small">@f.RoleLabel</span></td>
                                        <td class="small">@f.RelevanceScore</td>
                                        <td>@(f.IsRelevant ? "★" : "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    }
}
